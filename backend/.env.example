# =============================================================================
# Verida Compliance API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# Find these in: Supabase Dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# -----------------------------------------------------------------------------
# Anthropic Configuration
# Find your API key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-opus-4-6

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
DEBUG=false
APP_NAME=Verida Compliance API
APP_VERSION=2.0.0

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
STORAGE_BUCKET=documents
MAX_FILE_SIZE_MB=50

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.
# Include your frontend URL(s) here.
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://veridahq.com,https://www.veridahq.com,http://localhost:3000

# -----------------------------------------------------------------------------
# External storage integrations (SharePoint / OneDrive via Microsoft Graph)
#
# How to get these:
#   1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#   2. Click "New registration". Name it "Verida". Supported account types:
#      "Accounts in any organizational directory and personal Microsoft accounts".
#   3. Redirect URI: Web → https://verida-api.onrender.com/api/integrations/microsoft/callback
#   4. After creation, copy the "Application (client) ID" → MICROSOFT_CLIENT_ID
#   5. Under "Certificates & secrets" → New client secret → copy the VALUE (not the ID)
#      → MICROSOFT_CLIENT_SECRET
#   6. Under "API permissions" → Add a permission → Microsoft Graph → Delegated:
#        - Files.Read.All
#        - Sites.Read.All
#        - User.Read
#        - offline_access
#      Then click "Grant admin consent for <your tenant>" if you have a tenant.
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://verida-api.onrender.com/api/integrations/microsoft/callback

# Secret used to sign the OAuth `state` parameter (10-min TTL). Any long random
# string. If unset, the app falls back to SECRET_KEY or SUPABASE_SERVICE_KEY.
INTEGRATIONS_STATE_SECRET=

# Where the OAuth callback sends the user back to after a successful connect.
FRONTEND_SETTINGS_URL=https://veridahq.com/app.html#settings
