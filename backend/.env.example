# =============================================================================
# Verida Compliance API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# Find these in: Supabase Dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# -----------------------------------------------------------------------------
# Anthropic Configuration
# Find your API key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-opus-4-6

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
DEBUG=false
APP_NAME=Verida Compliance API
APP_VERSION=2.0.0

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
STORAGE_BUCKET=documents
MAX_FILE_SIZE_MB=50

# -----------------------------------------------------------------------------
# Microsoft / Azure AD — SharePoint & OneDrive Integration
# See README section "Azure AD App Registration" for setup instructions.
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=your-azure-ad-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-ad-client-secret-value
# Must match the Redirect URI configured in the Azure portal:
MICROSOFT_REDIRECT_URI=https://verida-api.onrender.com/api/integrations/microsoft/callback

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.
# Include your frontend URL(s) here.
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://veridahq.com,https://www.veridahq.com,http://localhost:3000

# =============================================================================
# Azure AD App Registration — Quick-start Guide
# =============================================================================
#
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#    → New registration
#      Name:           Verida Compliance
#      Supported account types: Accounts in any organisational directory
#                               (Multitenant) + personal Microsoft accounts
#      Redirect URI:   Web → https://verida-api.onrender.com/api/integrations/microsoft/callback
#    → Register
#
# 2. Copy "Application (client) ID" → MICROSOFT_CLIENT_ID above.
#
# 3. API permissions → Add a permission → Microsoft Graph → Delegated:
#      Files.Read.All
#      Sites.Read.All
#      User.Read
#      offline_access   (added automatically with offline_access scope)
#    → Grant admin consent for your directory.
#
# 4. Certificates & secrets → New client secret → copy the VALUE (not ID)
#    → MICROSOFT_CLIENT_SECRET above.
#    Note: secrets expire — rotate before the expiry date.
#
# 5. Set MICROSOFT_CLIENT_ID, MICROSOFT_CLIENT_SECRET, MICROSOFT_REDIRECT_URI
#    as environment variables on Render (Environment → Add Variable).
# =============================================================================
